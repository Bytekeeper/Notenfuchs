# Copy this file to .env before running `docker compose up`.

# The password for the one fixed local login user (username "lehrer" - see
# de.notenfuchs.security.LocalAuthConfigSource; change that literal + rebuild
# if you want a different username). This is the default/turbo auth path -
# nothing else needs configuring. Leave this unset ONLY if you're using the
# docker-compose.oidc.yml overlay for external SSO instead (see the README's
# "Authentication" section) - the app refuses to start in production with
# neither this nor an OIDC issuer configured.
NOTENFUCHS_PASSWORD=

# --- Everything below is only needed for the optional OIDC overlay ---------
# (`docker compose -f docker-compose.yml -f docker-compose.oidc.yml up`, see
# the README's "Option B: multi-user, Pocket ID SSO" section). Leave these
# blank for the default local-auth setup above.

# Uncomment to avoid typing both -f flags above every time - Compose reads
# COMPOSE_FILE from .env automatically, so plain `docker compose up` (and
# down/logs/...) will then merge both files with no flags needed.
# COMPOSE_FILE=docker-compose.yml:docker-compose.oidc.yml

# The full URL Pocket ID is externally reachable at, scheme included.
# "http://localhost:1411" (the default) works out of the box for running
# Notenfuchs on your own desktop. If you're putting a TLS-terminating reverse
# proxy in front of Pocket ID instead (recommended for anyone but you - and
# required by most browsers for WebAuthn/passkeys to work at all off
# localhost), point this at the proxy's public URL instead, e.g.
# "https://id.example.com" - no ":1411" needed once the proxy is what's
# actually terminating the connection on 443 and forwarding to the
# pocket-id container. Also set TRUST_PROXY below in that case.
POCKET_ID_APP_URL=http://localhost:1411

# Whether Pocket ID should trust reverse-proxy headers (X-Forwarded-For/-Proto)
# for the client's real IP/scheme - needed whenever POCKET_ID_APP_URL points
# through a reverse proxy (see above), otherwise leave as "false". Accepts
# "true", "false", or a comma-separated list of trusted proxy IPs/CIDRs.
TRUST_PROXY=false

# docker-compose.oidc.yml assumes Pocket ID always sits behind a reverse
# proxy (WebAuthn/passkeys need a secure context anyway) and binds its
# published port to localhost only, so it's unreachable except through that
# proxy. This is still "http://localhost:1411" out of the box if your
# browser and the proxy are the only things that need to reach it on the
# same machine. Only change this if your reverse proxy runs on a *different*
# host than this Compose stack and needs to reach this port over the
# network - e.g. set to 0.0.0.0, and make sure your firewall (not Compose)
# still restricts who can actually reach it.
POCKET_ID_HOST_BIND=127.0.0.1

# Set to "true" if Notenfuchs itself - not just Pocket ID - also sits behind
# a TLS-terminating reverse proxy (e.g. both are reachable through the same
# Caddy/nginx/Traefik instance on a real domain). Without this, Notenfuchs
# builds its OIDC callback URL as http://... (since the container only ever
# sees plain HTTP from the proxy), which won't match the https://... callback
# URL you register in Pocket ID, and login will fail. Leave "false" if you're
# hitting Notenfuchs directly (e.g. http://localhost:8080, no proxy in front
# of the app itself).
OIDC_TRUST_PROXY=false

# If OIDC_TRUST_PROXY above is "true", also set this to 127.0.0.1 (matching
# POCKET_ID_HOST_BIND above) so Notenfuchs' own port is only reachable
# through your reverse proxy too, not directly. This one lives in the base
# docker-compose.yml (used for Option A as well), so it stays "0.0.0.0" -
# reachable on your network directly - by default; only change it once
# you've actually got a proxy in front of the app.
APP_HOST_BIND=0.0.0.0

# Required by Pocket ID (the bundled OIDC provider), generate once with:
#   openssl rand -base64 32
POCKET_ID_ENCRYPTION_KEY=

# Set after creating the Notenfuchs OIDC client by hand in Pocket ID's admin
# UI (see the README's "Option B: multi-user, Pocket ID SSO" section) - paste
# the generated Client Secret here, then `docker compose up -d app` to pick
# it up.
OIDC_CLIENT_SECRET=
