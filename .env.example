# Copy this file to .env before running `docker compose up`. See the
# README's "Setting up Pocket ID" section for the full walkthrough.

# Hostname the compose stack is reachable at. "localhost" works out of the
# box for running Notenfuchs on your own desktop. If you're hosting this for
# others, set it to your real domain and see the README for the extra steps
# (reverse proxy, TLS, TRUST_PROXY=true) that implies.
BASE_URL=localhost

# Required by Pocket ID (the bundled OIDC provider), generate once with:
#   openssl rand -base64 32
POCKET_ID_ENCRYPTION_KEY=
POCKET_ID_STATIC_API_KEY=

# Printed by the pocket-id-bootstrap service the first time it registers
# Notenfuchs as an OIDC client (`docker compose logs pocket-id-bootstrap`).
# Paste the value here, then `docker compose up -d app`.
OIDC_CLIENT_SECRET=
